# Exclude VCS metadata and local build products from Docker context
.git/
.gitignore
.github/
.vscode/
.DS_Store

# Python cache / virtualenv
__pycache__/
**/__pycache__/
*.pyc
.venv/
venv/

# Build output
build/
cmake-build-*/
docs/
artifacts/
badges/
**/*.o
**/*.obj
**/*.a
**/*.lib
**/*.dll
**/*.so
**/*.dylib
**/CMakeCache.txt
**/CMakeFiles/

# Logs and local reports
*.log
.pytest_cache/
.mypy_cache/
.ruff_cache/
coverage/
.coverage
