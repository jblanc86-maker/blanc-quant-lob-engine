#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd)"
legacy_sg="${script_dir}/../tools/legacy/signalgrid/sg"

if [[ ! -x "$legacy_sg" ]]; then
  echo "legacy SignalGrid shim is missing or not executable: $legacy_sg" >&2
  exit 2
fi

exec "$legacy_sg" "$@"
